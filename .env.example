# Database Configuration
AIVEN_PG_HOST=YOUR_aiven-host.aivencloud.com
AIVEN_PG_PORT=25060
AIVEN_PG_DATABASE=kenyan_climate_db
AIVEN_PG_USER=avnadmin
AIVEN_PG_PASSWORD=YOUR_secure-password
AIVEN_PG_SSL_MODE=require
DATABASE_URL=postgresql://${AIVEN_PG_USER}:${AIVEN_PG_PASSWORD}@${AIVEN_PG_HOST}:${AIVEN_PG_PORT}/${AIVEN_PG_DATABASE}?sslmode=require

# API Keys
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
NOAA_API_KEY=YOUR_noaa-api-key

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=YOUR_super-secret-key-change-in-production
JWT_SECRET=YOUR_jwt-secret-key
CORS_ORIGINS=http://localhost:3000,https://YOUR_frontend.vercel.app

# ML Service Configuration
ML_SERVICE_PORT=5001
MODEL_PATH=./ml-service/models
DATA_PATH=./ml-service/data
RETRAIN_SCHEDULE=0 12 * * 6

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME
GF_SERVER_ROOT_URL=https://YOUR_domain.com/grafana

# Nginx Configuration
NGINX_PORT=80
NGINX_SSL_PORT=443
DOMAIN=YOUR_domain.com

# Redis/Caching
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO
